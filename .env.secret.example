# Template for the st0x-issuance.env.age secret.
# DO NOT commit a populated version of this file — it contains credentials.
#
# To create the encrypted secret:
#   1. Copy this file: cp example.secrets.env /tmp/st0x-issuance.env
#   2. Fill in the values below.
#   3. Encrypt: ragenix --rules ./secret/secrets.nix -e st0x-issuance.env.age \
#        -i ~/.ssh/id_ed25519 < /tmp/st0x-issuance.env
#   4. Verify: ragenix --rules ./secret/secrets.nix -d st0x-issuance.env.age \
#        -i ~/.ssh/id_ed25519
#   5. Delete plaintext: rm /tmp/st0x-issuance.env
#
# The encrypted file is committed at secret/st0x-issuance.env.age.
# The Fireblocks RSA private key is a separate secret: secret/fireblocks-secret-issuance.key.age

RPC_URL=${RPC_URL}
FIREBLOCKS_API_USER_ID=${FIREBLOCKS_API_USER_ID}
ISSUER_API_KEY=${ISSUER_API_KEY}
ALPACA_IP_RANGES=${ALPACA_IP_RANGES}
INTERNAL_IP_RANGES=127.0.0.0/8,::1/128,172.16.0.0/12,${INTERNAL_IP_RANGES_EXTRA}
ALPACA_API_BASE_URL=${ALPACA_API_BASE_URL}
ALPACA_ACCOUNT_ID=${ALPACA_ACCOUNT_ID}
ALPACA_API_KEY=${ALPACA_API_KEY}
ALPACA_API_SECRET=${ALPACA_API_SECRET}
HYPERDX_API_KEY=${HYPERDX_API_KEY}
SUBGRAPH_URL=${SUBGRAPH_URL}
# Gates dev-only surfaces (OpenAPI docs / Swagger UI). Pinned to `production`
# so the deployed image never exposes them; unset also defaults to production.
ENVIRONMENT=production
